{
  "name": "@crediblemark/build",
  "version": "0.25.20",
  "description": "The open-source visual editor for React",
  "author": "Rasyiqi Crediblemark",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crediblemark-official/credbuild.git",
    "directory": "."
  },
  "bugs": "https://crediblemark.com/id/contact",
  "homepage": "https://blog.crediblemark.com/",
  "keywords": [
    "credbuild",
    "visual",
    "editor",
    "react",
    "drag and drop",
    "dnd",
    "page",
    "website",
    "builder",
    "headless",
    "cms",
    "low-code",
    "no-code",
    "javascript",
    "typescript",
    "WYSIWYG"
  ],
  "private": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "react-server": {
        "types": "./dist/rsc.d.ts",
        "import": "./dist/rsc.mjs",
        "require": "./dist/rsc.js"
      },
      "default": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      }
    },
    "./rsc": {
      "types": "./dist/rsc.d.ts",
      "import": "./dist/rsc.mjs",
      "require": "./dist/rsc.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.mjs",
      "require": "./dist/internal.js"
    },
    "./credbuild.css": "./dist/index.css",
    "./no-external.css": "./dist/no-external.css",
    "./dist/index.css": "./dist/index.css",
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "rsc": [
        "./dist/rsc.js"
      ]
    }
  },
  "license": "MIT",
  "scripts": {
    "lint": "eslint \"**/*.ts*\"",
    "build": "rm -rf dist && tsup bundle/index.ts bundle/rsc.tsx bundle/no-external.ts bundle/internal.ts",
    "dev": "tsup bundle/index.ts bundle/rsc.tsx bundle/no-external.ts bundle/internal.ts --watch",
    "test": "jest",
    "prepublishOnly": "bun run build"
  },
  "bin": {
    "credbuild": "bin/credbuild.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@juggle/resize-observer": "^3.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/deep-diff": "^1.0.5",
    "@types/flat": "^5.0.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.12.2",
    "@types/object-hash": "^3.0.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "css-box-model": "^1.2.1",
    "eslint": "^8.57.1",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "happy-dom": "^20.9.0",
    "lucide-react": "^0.556.0",
    "madge": "^8.0.0",
    "postcss": "^8.5.14",
    "postcss-modules": "^6.0.1",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "5.4.5"
  },
  "dependencies": {
    "@dnd-kit/abstract": "0.1.21",
    "@dnd-kit/collision": "0.1.21",
    "@dnd-kit/dom": "0.1.21",
    "@dnd-kit/geometry": "0.1.21",
    "@dnd-kit/helpers": "0.1.18",
    "@dnd-kit/react": "0.1.18",
    "@dnd-kit/state": "0.1.21",
    "@radix-ui/react-popover": "^1.1.15",
    "@tanstack/react-virtual": "^3.13.24",
    "@tiptap/core": "^3.22.5",
    "@tiptap/extension-blockquote": "^3.22.5",
    "@tiptap/extension-bold": "^3.22.5",
    "@tiptap/extension-code": "^3.22.5",
    "@tiptap/extension-code-block": "^3.22.5",
    "@tiptap/extension-document": "^3.22.5",
    "@tiptap/extension-hard-break": "^3.22.5",
    "@tiptap/extension-heading": "^3.22.5",
    "@tiptap/extension-horizontal-rule": "^3.22.5",
    "@tiptap/extension-italic": "^3.22.5",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/extension-list": "^3.22.5",
    "@tiptap/extension-paragraph": "^3.22.5",
    "@tiptap/extension-strike": "^3.22.5",
    "@tiptap/extension-text": "^3.22.5",
    "@tiptap/extension-text-align": "^3.22.5",
    "@tiptap/extension-underline": "^3.22.5",
    "@tiptap/html": "^3.22.5",
    "@tiptap/pm": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "classnames": "^2.5.1",
    "deep-diff": "^1.0.2",
    "fast-equals": "5.2.2",
    "flat": "^5.0.2",
    "isomorphic-dompurify": "^3.12.0",
    "object-hash": "^3.0.0",
    "react-hotkeys-hook": "^4.6.2",
    "use-debounce": "^9.0.4",
    "uuid": "^9.0.1",
    "zustand": "^5.0.13"
  },
  "peerDependencies": {
    "react": "^19.2.6"
  }
}
